SaveGameManager="*uid://c6eimj33laors"
DialogueManager="*uid://c3rodes2l3gxb"
GameDialogueManager="*uid://dpydxtfpnv24h"
GameManager="*uid://drvqg40a3x4l3"
SceneManager="*uid://colokbxcht5q3"

[display]

